<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- Big speed display -->
    <LinearLayout
        android:id="@+id/speedBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_panel_accent"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/speed"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.3"/>

        <TextView
            android:id="@+id/speedValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.0"
            android:textColor="@color/neon_red"
            android:textSize="96sp"
            android:fontFamily="sans-serif-condensed"
            android:textStyle="bold"
            android:letterSpacing="-0.05"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/kmh"
            android:textColor="@color/neon_orange"
            android:textSize="14sp"
            android:letterSpacing="0.2"/>

    </LinearLayout>

    <!-- Stats grid -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/statsGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/speedBlock"
        app:layout_constraintBottom_toTopOf="@id/stopBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/cellTime"
            style="@style/StatCell"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cellDist">
            <TextView style="@style/StatLabel" android:text="@string/time"/>
            <TextView android:id="@+id/timeValue" style="@style/StatValue" android:text="00:00"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cellDist"
            style="@style/StatCell"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/cellTime"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView style="@style/StatLabel" android:text="@string/distance"/>
            <TextView android:id="@+id/distValue" style="@style/StatValue" android:text="0.00 km"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cellMax"
            style="@style/StatCell"
            app:layout_constraintTop_toBottomOf="@id/cellTime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cellAvg">
            <TextView style="@style/StatLabel" android:text="@string/max_speed"/>
            <TextView android:id="@+id/maxSpeedValue" style="@style/StatValue" android:text="0.0"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cellAvg"
            style="@style/StatCell"
            app:layout_constraintTop_toBottomOf="@id/cellDist"
            app:layout_constraintStart_toEndOf="@id/cellMax"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView style="@style/StatLabel" android:text="@string/avg_speed"/>
            <TextView android:id="@+id/avgSpeedValue" style="@style/StatValue" android:text="0.0"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cellGain"
            style="@style/StatCell"
            app:layout_constraintTop_toBottomOf="@id/cellMax"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/cellAlt">
            <TextView style="@style/StatLabel" android:text="@string/elevation_gain"/>
            <TextView android:id="@+id/gainValue" style="@style/StatValue" android:text="0 m"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cellAlt"
            style="@style/StatCell"
            app:layout_constraintTop_toBottomOf="@id/cellAvg"
            app:layout_constraintStart_toEndOf="@id/cellGain"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView style="@style/StatLabel" android:text="@string/max_altitude"/>
            <TextView android:id="@+id/altValue" style="@style/StatValue" android:text="0 m"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <Button
        android:id="@+id/stopBtn"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/btn_stop"
        android:text="@string/stop_run"
        android:textColor="@color/neon_red"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
